    {
      "path": "registry/default/example/cosmic-button-demo.tsx",
      "content": "\"use client\"\n\nimport { CosmicButton } from \"@/registry/default/ui/cosmic-button\"\n\nexport default function CosmicButtonDemo() {\n  return (\n    <div className=\"dark:bg-stone-950 py-6 px-4 md:px-0 rounded-md flex justify-center\">\n      <div>\n        <div className=\"flex flex-col gap-6 max-w-lg mt-4\">\n          <div className=\"flex flex-wrap gap-3 items-center\">\n            <CosmicButton href=\"/about\">About</CosmicButton>\n            <CosmicButton href=\"https://github.com\">GitHub</CosmicButton>\n            <CosmicButton as=\"button\" onClick={() => alert(\"Clicked!\")}>\n              Submit\n            </CosmicButton>\n          </div>\n          <div className=\"flex flex-wrap gap-3 items-center\">\n            <CosmicButton href=\"/docs\">View Docs</CosmicButton>\n            <CosmicButton as=\"button\" type=\"button\">\n              Default Button\n            </CosmicButton>\n          </div>\n        </div>\n      </div>\n    </div>\n  )\n}\n",
      "type": "registry:component"
    }
  ],
  "type": "registry:component"
}